# ── AlphaLens Environment Configuration ──────────────────────────────────────
# Copy to .env and fill in. Never commit .env to git.

# ── Database paths ────────────────────────────────────────────────────────
DUCKDB_PATH=data/alphalens.duckdb
SQLITE_PATH=data/alphalens.db

# ── Zerodha Kite Connect ──────────────────────────────────────────────────
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=your_daily_token_here
KITE_USER_ID=your_user_id
KITE_PASSWORD=your_password
KITE_TOTP_SECRET=your_totp_secret

# ── Telegram Bot ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Email / SMTP ──────────────────────────────────────────────────────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=your_email@gmail.com

# ── Application ───────────────────────────────────────────────────────────
APP_ENV=development           # development | production
LOG_LEVEL=INFO
DASHBOARD_PORT=8050
DASHBOARD_HOST=127.0.0.1

# ── Capital Configuration (overridden by DB config table) ─────────────────
TOTAL_CAPITAL=2500000
INTRADAY_CAPITAL=250000
SWING_CAPITAL=500000
MEDIUM_CAPITAL=750000
LONGTERM_CAPITAL=1000000

# ── Portfolio Slots ───────────────────────────────────────────────────────
INTRADAY_SLOTS=3
SWING_SLOTS=5
MEDIUM_SLOTS=8
LONGTERM_SLOTS=15

# ── ML Thresholds ─────────────────────────────────────────────────────────
SIGNAL_THRESHOLD_BULL=0.65
SIGNAL_THRESHOLD_NEUTRAL=0.75
SIGNAL_THRESHOLD_BEAR=0.85
MIN_RISK_REWARD=1.5
